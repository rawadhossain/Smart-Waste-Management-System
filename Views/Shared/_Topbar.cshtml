<div class="d-flex justify-content-between align-items-center w-100 py-3 px-1">

    <div class="d-flex align-items-center gap-3">
        <button id="btnSidebar" class="btn btn-icon btn-light d-lg-none border shadow-sm" type="button">
            <i class="bi bi-list fs-5"></i>
        </button>

        <div>
            <h1 class="h5 mb-0 fw-bold tracking-tight text-dark">@ViewData["Title"]</h1>
            <small class="text-muted fw-medium d-block mt-n1">
                <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("dddd, dd MMM yyyy")
            </small>
        </div>
    </div>

    <div class="d-flex align-items-center gap-2">
        @if (User?.Identity?.IsAuthenticated ?? false)
        {
            <div class="d-flex align-items-center bg-white border rounded-pill px-3 py-1 shadow-sm me-2">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px;">
                    <i class="bi bi-person text-white fs-7"></i>
                </div>
                <span class="fw-semibold text-secondary small">@User.Identity!.Name</span>
            </div>

            <form method="post"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="/Auth"
                  asp-antiforgery="true"
                  class="m-0">
                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold transition-all">
                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                </button>
            </form>
        }
        else
        {
            <a class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm fw-bold" href="/Identity/Account/Login">
                <i class="bi bi-box-arrow-in-right me-1"></i> Login
            </a>
        }
    </div>
</div>

<style>
    /* Custom refinements to complement Bootstrap */
    .btn-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
    }

    .tracking-tight {
        letter-spacing: -0.02em;
    }

    .fs-7 {
        font-size: 0.8rem;
    }

    .transition-all {
        transition: all 0.2s ease-in-out;
    }

    .btn-outline-danger:hover {
        background-color: #fff5f5;
        color: #dc3545;
    }
</style>